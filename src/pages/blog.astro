---
import BaseLayout from '../layouts/BaseLayout.astro';

// Sample blog posts — these will be replaced with Content Collections later
const posts = [
  {
    title: 'Cómo identificar y superar creencias limitantes',
    excerpt: 'Las creencias limitantes son pensamientos arraigados que nos frenan. Descubre cómo identificarlas y transformarlas en impulso para tu crecimiento.',
    date: '2026-03-01',
    category: 'Desarrollo Personal',
    readTime: '5 min',
    slug: '#',
  },
  {
    title: 'Los 5 pilares del bienestar holístico',
    excerpt: 'El bienestar verdadero va más allá de lo físico. Explora los cinco pilares fundamentales para una vida equilibrada y plena.',
    date: '2026-02-20',
    category: 'PSICOLISTICA',
    readTime: '7 min',
    slug: '#',
  },
  {
    title: 'Liderazgo consciente: guiar desde la autenticidad',
    excerpt: 'El liderazgo más efectivo nace de la autenticidad. Descubre cómo liderar con propósito y conexión real con tu equipo.',
    date: '2026-02-10',
    category: 'Coaching Ejecutivo',
    readTime: '6 min',
    slug: '#',
  },
  {
    title: 'Gestión emocional en tiempos de cambio',
    excerpt: 'Los momentos de incertidumbre pueden ser los más transformadores. Aprende herramientas para navegar el cambio con resiliencia.',
    date: '2026-01-28',
    category: 'Psicología',
    readTime: '4 min',
    slug: '#',
  },
  {
    title: 'Coaching de equipos: claves para la cohesión',
    excerpt: 'Un equipo cohesionado es más que la suma de sus partes. Descubre las dinámicas que transforman grupos en equipos de alto rendimiento.',
    date: '2026-01-15',
    category: 'Coaching Ejecutivo',
    readTime: '8 min',
    slug: '#',
  },
  {
    title: 'El poder de la intención: conectando mente y propósito',
    excerpt: 'Establecer intenciones claras es el primer paso hacia la transformación personal. Aprende a alinear tus pensamientos con tus metas.',
    date: '2026-01-05',
    category: 'Desarrollo Personal',
    readTime: '5 min',
    slug: '#',
  },
];

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout
  title="Blog"
  description="Artículos sobre coaching, psicología, desarrollo personal y bienestar holístico por Nagore Sanz, coach certificada ICC."
>

  <section class="page-hero" id="page-hero-blog">
    <div class="container">
      <span class="page-hero__overline fade-in">Blog</span>
      <h1 class="page-hero__title fade-in delay-1">Reflexiones y recursos</h1>
      <p class="page-hero__subtitle fade-in delay-2">
        Artículos sobre psicología, coaching y bienestar
      </p>
    </div>
  </section>

  <section class="blog section" id="blog-posts">
    <div class="container">
      <div class="blog__grid">
        {posts.map((post, i) => (
          <article class={`blog__card glass-card fade-in delay-${Math.min(i + 1, 3)}`} id={`blog-post-${i}`}>
            <div class="blog__card-image">
              <span class="blog__card-category">{post.category}</span>
            </div>
            <div class="blog__card-content">
              <div class="blog__card-meta">
                <time datetime={post.date}>{formatDate(post.date)}</time>
                <span>·</span>
                <span>{post.readTime} lectura</span>
              </div>
              <h2 class="blog__card-title">
                <a href={post.slug}>{post.title}</a>
              </h2>
              <p class="blog__card-excerpt">{post.excerpt}</p>
              <a href={post.slug} class="blog__card-link">
                Leer más
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    padding: calc(var(--header-height) + var(--space-4xl)) 0 var(--space-3xl);
    text-align: center;
    background: var(--gradient-warm);
  }
  .page-hero__overline {
    display: inline-block; font-size: var(--text-xs); font-weight: 700;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-golden); margin-bottom: var(--space-md);
  }
  .page-hero__title { font-size: var(--text-4xl); margin-bottom: var(--space-lg); }
  .page-hero__subtitle {
    font-family: var(--font-subheading); font-size: var(--text-xl); font-style: italic;
    color: var(--color-sage); max-width: 500px; margin: 0 auto;
  }

  .blog__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .blog__card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .blog__card-image {
    height: 200px;
    background: var(--gradient-warm);
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    padding: var(--space-md);
  }

  .blog__card-category {
    display: inline-block;
    background: var(--color-white);
    color: var(--color-sage-dark);
    font-size: var(--text-xs);
    font-weight: 600;
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-full);
    letter-spacing: 0.05em;
  }

  .blog__card-content {
    padding: var(--space-xl);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .blog__card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-xs);
    color: var(--color-sage);
    margin-bottom: var(--space-md);
  }

  .blog__card-title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-md);
    line-height: 1.3;
  }

  .blog__card-title a {
    transition: color var(--transition-fast);
  }

  .blog__card-title a:hover {
    color: var(--color-sage);
  }

  .blog__card-excerpt {
    font-size: var(--text-sm);
    opacity: 0.8;
    flex: 1;
    line-height: 1.7;
  }

  .blog__card-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-sage-dark);
    transition: all var(--transition-fast);
    margin-top: var(--space-md);
  }

  .blog__card-link:hover {
    gap: var(--space-sm);
    color: var(--color-golden);
  }

  @media (max-width: 768px) {
    .blog__grid { grid-template-columns: 1fr; max-width: 500px; margin: 0 auto; }
  }
</style>
