---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contacto"
  description="Contacta con Nagore Sanz, coach personal y ejecutiva en Arteixo, A Coruña. Reserva tu sesión de coaching o solicita información."
>
  <section class="page-hero" id="page-hero-contact">
    <div class="container">
      <span class="page-hero__overline fade-in">Contacto</span>
      <h1 class="page-hero__title fade-in delay-1">Hablemos</h1>
      <p class="page-hero__subtitle fade-in delay-2">
        El primer paso hacia tu transformación empieza aquí
      </p>
    </div>
  </section>

  <section class="contact section" id="contact-section">
    <div class="container">
      <div class="contact__grid">
        <!-- Contact Info -->
        <div class="contact__info fade-in-left">
          <h2>Ponte en <span class="text-secondary">contacto</span></h2>
          <div class="divider" style="margin-left:0"></div>
          <p>
            ¿Tienes preguntas sobre mis servicios? ¿Quieres reservar una sesión
            de descubrimiento? No dudes en escribirme. Estaré encantada de
            ayudarte.
          </p>

          <div class="contact__details">
            <div class="contact__detail" id="contact-address">
              <div class="contact__detail-icon">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                  ></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
              </div>
              <div>
                <h4>Ubicación</h4>
                <p>Av. de Santo Estevo de Morás<br />15142 Arteixo, A Coruña</p>
              </div>
            </div>

            <div class="contact__detail" id="contact-phone">
              <div class="contact__detail-icon contact__detail-icon--golden">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path
                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                  ></path>
                </svg>
              </div>
              <div>
                <h4>Teléfono</h4>
                <a href="tel:+34666146052">+34 666 14 60 52</a>
              </div>
            </div>

            <div class="contact__detail" id="contact-hours">
              <div class="contact__detail-icon contact__detail-icon--lavender">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="12" cy="12" r="10"></circle>
                  <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
              </div>
              <div>
                <h4>Horario</h4>
                <p>Lunes a Viernes: 10:00 – 19:30<br />Con cita previa</p>
              </div>
            </div>
          </div>

          <div class="contact__social">
            <h4>Sígueme en redes</h4>
            <div class="contact__social-links">
              <a
                href="https://www.instagram.com/nagore_sanz_/"
                target="_blank"
                rel="noopener noreferrer"
                class="contact__social-link"
                aria-label="Instagram"
              >
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                  ></path>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                </svg>
                <span>@nagoresanz_coach</span>
              </a>
              <a
                href="https://es.linkedin.com/in/nasanzcoach"
                target="_blank"
                rel="noopener noreferrer"
                class="contact__social-link"
                aria-label="LinkedIn"
              >
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path
                    d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                  ></path>
                  <rect x="2" y="9" width="4" height="12"></rect>
                  <circle cx="4" cy="4" r="2"></circle>
                </svg>
                <span>PSICOLISTICA NGM</span>
              </a>
            </div>
          </div>
        </div>

        <div class="contact__form-wrapper fade-in-right">
          <div class="contact__success-state glass-card" id="success-msg" style="display: none;">
            <div class="contact__success-icon">
              <svg
                width="48"
                height="48"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
            </div>
            <h3>¡Mensaje enviado!</h3>
            <p>Muchas gracias por contactar conmigo. He recibido tu mensaje correctamente y te responderé en breve.</p>
            <button class="btn btn--primary" id="reset-btn">Enviar otro mensaje</button>
          </div>

          <form
            class="contact__form glass-card"
            id="contact-form"
            action="https://form-mailer.dinaserver.com/"
            method="POST"
            enctype="multipart/form-data"
            target="hidden_iframe"
          >
            <h3>Envíame un mensaje</h3>
            <p class="contact__form-subtitle">
              Respondo en menos de 24 horas laborables.
            </p>

            <!-- Datos de configuración del hosting (DinaServer) -->
            <input type="hidden" name="redirigir" value="https://www.nagoresanz.com/gracias.html" />
            <input type="hidden" name="recipe" value="zoobliminal@gmail.com" />
            <input type="hidden" name="asunto" value="Envío formulario desde nagoresanz.com" />
            <!-- Solo Email, Condiciones y el campo formateado son requeridos por DinaServer para evitar duplicados -->
            <input type="hidden" name="required" value="Email;Acepto_Condiciones;Mensaje_Formateado" />
            <input type="hidden" name="dominio" value="nagoresanz.com" />
            <input type="hidden" name="idioma" value="es" />

            <!-- Este campo recopilará todo el mensaje formateado -->
            <input type="hidden" id="Mensaje_Formateado" name="Mensaje_Formateado" />

            <div class="contact__form-group">
              <label for="nombre">Nombre completo *</label>
              <input
                type="text"
                id="nombre"
                name="Nombre_Simple"
                required
                placeholder="Tu nombre"
              />
            </div>

            <div class="contact__form-group">
              <label for="email">Cuenta de correo *</label>
              <input
                type="email"
                id="email"
                name="Email"
                required
                placeholder="tu@email.com"
              />
            </div>

            <div class="contact__form-group">
              <label for="telefono">Teléfono</label>
              <input
                type="tel"
                id="telefono"
                name="Telefono_Simple"
                placeholder="+34 600 000 000"
              />
            </div>

            <div class="contact__form-group">
              <label for="queteinteresa">¿Qué servicio te interesa?</label>
              <textarea
                id="queteinteresa"
                name="Interes_Simple"
                rows="3"
                placeholder="Dime qué servicio buscas..."></textarea>
            </div>

            <div class="contact__form-group">
              <label for="ayuda">¿Cómo puedo ayudarte? *</label>
              <textarea
                id="ayuda"
                name="Mensaje_Simple"
                required
                rows="4"
                placeholder="Cuéntame brevemente tu situación..."></textarea>
            </div>

            <div class="contact__form-group contact__form-group--checkbox">
              <input type="checkbox" id="legal" name="Acepto_Condiciones" required />
              <label for="legal">
                Acepto las <a href="/legal" target="_blank">condiciones legales</a> y la política de privacidad. *
              </label>
            </div>

            <div class="contact__form-group contact__form-group--captcha">
              <label for="entradaVerificacion">Verificación de seguridad *</label>
              <div class="contact__captcha-wrapper">
                <span id="muestraVerificacion" class="contact__captcha-text"></span>
                <input type="hidden" id="verificacionOculto" name="verificacionOculto"/>
                <input
                  type="text"
                  id="entradaVerificacion"
                  name="entradaVerificacion"
                  required
                  placeholder="?"
                  style="width: 80px;"
                />
              </div>
              <p class="contact__form-help">Resuelve esta sencilla suma para enviar el mensaje.</p>
            </div>

            <button
              type="submit"
              class="btn btn--primary contact__form-submit"
              id="submit-btn"
            >
              <span id="btn-text">Enviar mensaje</span>
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="22" y1="2" x2="11" y2="13"></line>
                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
              </svg>
            </button>
          </form>
          <!-- Iframe invisible para evitar redirección -->
          <iframe name="hidden_iframe" id="hidden_iframe" style="display:none;"></iframe>
        </div>
      </div>
    </div>
  </section>




  <!-- Map Section -->
  <section class="map-section" id="map">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d23250.76!2d-8.51!3d43.30!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd2e7f0e0e0e0e01%3A0x0!2sArteixo%2C%20A%20Coru%C3%B1a!5e0!3m2!1ses!2ses!4v1"
      width="100%"
      height="400"
      style="border:0;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Ubicación de Nagore Sanz en Arteixo, A Coruña"></iframe>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: calc(var(--header-height) + var(--space-4xl)) 0 var(--space-3xl);
    text-align: center;
    background: var(--gradient-warm);
  }
  .page-hero__overline {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }
  .page-hero__title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-lg);
  }
  .page-hero__subtitle {
    font-family: var(--font-subheading);
    font-size: var(--text-xl);
    font-style: italic;
    color: var(--color-primary);
    max-width: 500px;
    margin: 0 auto;
  }

  /* Contact Grid */
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-4xl);
    align-items: flex-start;
  }

  .contact__info h2 {
    margin-bottom: var(--space-sm);
  }

  .contact__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    margin: var(--space-2xl) 0;
  }

  .contact__detail {
    display: flex;
    gap: var(--space-lg);
    align-items: flex-start;
  }

  .contact__detail-icon {
    width: 50px;
    height: 50px;
    border-radius: var(--radius-lg);
    background: rgba(124, 154, 130, 0.1);
    color: var(--color-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact__detail-icon--golden {
    background: rgba(196, 149, 106, 0.1);
    color: var(--color-accent);
  }
  .contact__detail-icon--lavender {
    background: rgba(184, 169, 201, 0.1);
    color: var(--color-secondary-light);
  }

  .contact__detail h4 {
    font-size: var(--text-sm);
    margin-bottom: var(--space-xs);
  }

  .contact__detail p,
  .contact__detail a {
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    opacity: 0.8;
    margin: 0;
  }

  .contact__detail a:hover {
    color: var(--color-accent);
  }

  /* Social */
  .contact__social {
    margin-top: var(--space-2xl);
  }
  .contact__social h4 {
    font-size: var(--text-sm);
    margin-bottom: var(--space-md);
  }

  .contact__social-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact__social-link {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    color: var(--color-charcoal);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: all var(--transition-fast);
  }

  .contact__social-link:hover {
    color: var(--color-secondary);
    transform: translateX(4px);
  }

  /* Form */
  .contact__form {
    padding: var(--space-2xl);
  }

  .contact__form h3 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-xs);
  }

  .contact__form-subtitle {
    font-size: var(--text-sm);
    color: var(--color-primary-light);
    margin-bottom: var(--space-xl);
  }

  /* Success State */
  .contact__success-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-3xl) var(--space-2xl);
    min-height: 400px;
    animation: fadeIn var(--transition-base);
  }

  .contact__success-icon {
    width: 80px;
    height: 80px;
    background: rgba(124, 154, 130, 0.1);
    color: var(--color-secondary);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-xl);
  }

  .contact__success-state h3 {
    font-size: var(--text-2xl);
    color: var(--color-primary);
    margin-bottom: var(--space-md);
  }

  .contact__success-state p {
    font-size: var(--text-base);
    color: var(--color-charcoal);
    max-width: 400px;
    margin-bottom: var(--space-2xl);
    line-height: 1.6;
  }

  .contact__form-group {
    margin-bottom: var(--space-lg);
  }

  .contact__form-group label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .contact__form-group input,
  .contact__form-group select,
  .contact__form-group textarea {
    width: 100%;
    padding: var(--space-md) var(--space-lg);
    border: 2px solid rgba(124, 154, 130, 0.15);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-charcoal);
    background: var(--color-ivory);
    transition: all var(--transition-fast);
    outline: none;
  }

  .contact__form-group input:focus,
  .contact__form-group select:focus,
  .contact__form-group textarea:focus {
    border-color: var(--color-secondary);
    box-shadow: 0 0 0 3px rgba(124, 154, 130, 0.1);
  }

  .contact__form-group input::placeholder,
  .contact__form-group textarea::placeholder {
    color: var(--color-charcoal);
    opacity: 0.4;
  }

  .contact__form-group select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%237C9A82' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right var(--space-md) center;
    padding-right: var(--space-2xl);
  }

  .contact__form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact__form-group--checkbox {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
  }

  .contact__form-group--checkbox input {
    width: auto;
    margin-top: 4px;
    cursor: pointer;
  }

  .contact__form-group--checkbox label {
    font-weight: 400;
    cursor: pointer;
    line-height: 1.5;
  }

  .contact__form-group--checkbox a {
    color: var(--color-secondary);
    text-decoration: underline;
  }

  .contact__form-group--captcha {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid rgba(124, 154, 130, 0.1);
  }

  .contact__captcha-wrapper {
    display: flex;
    gap: var(--space-md);
    align-items: center;
    margin-bottom: var(--space-xs);
  }

  .contact__captcha-text {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-primary);
    background: rgba(124, 154, 130, 0.1);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-md);
    font-family: monospace;
    letter-spacing: 0.1em;
  }

  .contact__form-help {
    font-size: var(--text-xs);
    color: var(--color-primary-light);
    margin-bottom: var(--space-md);
  }

  .contact__form-submit {
    width: 100%;
    justify-content: center;
    margin-top: var(--space-lg);
  }

  /* Map */
  .map-section {
    line-height: 0;
  }

  .map-section iframe {
    filter: grayscale(30%) contrast(1.1);
    transition: filter var(--transition-base);
  }

  .map-section iframe:hover {
    filter: grayscale(0%) contrast(1);
  }

  @media (max-width: 768px) {
    .contact__grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
    .contact__info {
      text-align: center;
    }
    .contact__details {
      align-items: center;
    }
    .contact__detail {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .contact__social {
      text-align: center;
    }
    .contact__social-links {
      align-items: center;
    }
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = document.getElementById("btn-text") as HTMLSpanElement;
  const legalCheck = document.getElementById("legal") as HTMLInputElement;
  const successMsg = document.getElementById("success-msg") as HTMLDivElement;
  const resetBtn = document.getElementById("reset-btn") as HTMLButtonElement;
  const iframe = document.getElementById("hidden_iframe") as HTMLIFrameElement;

  // Captcha Logic from DinaServer
  let a = Math.ceil(Math.random() * 10);
  let b = Math.ceil(Math.random() * 10);
  let c = a + b;

  function GenerarCaptcha() {
    const hidden = document.getElementById("verificacionOculto") as HTMLInputElement;
    const muestra = document.getElementById("muestraVerificacion");
    if (muestra && hidden) {
      muestra.innerHTML = a + " + " + b + " = ";
      hidden.value = c.toString();
    }
  }

  function ValidarCaptcha() {
    const inputField = document.getElementById("entradaVerificacion") as HTMLInputElement;
    if (inputField.value == c.toString()) {
      return true;
    } else {
      inputField.style.borderColor = "red";
      inputField.style.color = "red";
      return false;
    }
  }

  // Initializations
  GenerarCaptcha();

  // Legal Checkbox logic
  if (legalCheck && btn) {
    btn.setAttribute("disabled", "disabled");
    btn.style.opacity = "0.5";
    btn.style.cursor = "not-allowed";

    legalCheck.addEventListener("change", (event) => {
      const target = event.target as HTMLInputElement;
      if (target.checked) {
        btn.removeAttribute("disabled");
        btn.style.opacity = "1";
        btn.style.cursor = "pointer";
      } else {
        btn.setAttribute("disabled", "disabled");
        btn.style.opacity = "0.5";
        btn.style.cursor = "not-allowed";
      }
    });
  }

  // Handle Submission
  if (form && btn && btnText && successMsg) {
    form.addEventListener("submit", (e) => {
      // 1. Validar Captcha primero
      if (!ValidarCaptcha()) {
        e.preventDefault();
        alert("Por favor, resuelve correctamente la suma de verificación.");
        return;
      }

      // 2. Construir el mensaje formateado (Opción C)
      const nombreVal = (document.getElementById("nombre") as HTMLInputElement).value;
      const emailVal = (document.getElementById("email") as HTMLInputElement).value;
      const tlfVal = (document.getElementById("telefono") as HTMLInputElement).value || "No facilitado";
      const interesVal = (document.getElementById("queteinteresa") as HTMLTextAreaElement).value || "No especificado";
      const ayudaVal = (document.getElementById("ayuda") as HTMLTextAreaElement).value;
      const msgFormateado = document.getElementById("Mensaje_Formateado") as HTMLInputElement;

      if (msgFormateado) {
        msgFormateado.value = `
        
MENSAJE DE: ${nombreVal.toUpperCase()}
-----------------------------------------------------------
CONTACTO: ${emailVal} | TEL: ${tlfVal}

¿QUÉ LE INTERESA?:
${interesVal}

MENSAJE / CÓMO PUEDO AYUDARTE:
"${ayudaVal}"
-----------------------------------------------------------
Aceptó las condiciones legales.
        `;
      }

      // 3. Desactivar nombres de campos individuales para evitar duplicados en el PDF/Email de DinaServer
      // Pero dejamos Email y Acepto_Condiciones para que el servidor los procese normalmente
      (document.getElementById("nombre") as HTMLInputElement).removeAttribute("name");
      (document.getElementById("telefono") as HTMLInputElement).removeAttribute("name");
      (document.getElementById("queteinteresa") as HTMLTextAreaElement).removeAttribute("name");
      (document.getElementById("ayuda") as HTMLTextAreaElement).removeAttribute("name");
      
      // Mostrar estado de carga brevemente
      btn.classList.add("btn--disabled");
      btnText.textContent = "Enviando...";

      // Escuchar el evento de carga del iframe para confirmar que se procesó
      iframe.onload = () => {
        form.style.display = "none";
        successMsg.style.display = "flex";
        
        // Timeout para asegurar que el navegador procese el display:flex antes de la animación
        setTimeout(() => {
          successMsg.classList.add("fade-in", "visible");
        }, 10);
        
        window.scrollTo({ top: form.offsetTop - 100, behavior: 'smooth' });
      };
    });
  }

  // Reset Form
  if (resetBtn && form && successMsg) {
    resetBtn.addEventListener("click", () => {
      form.reset();
      form.style.display = "block";
      successMsg.style.display = "none";
      btn.classList.remove("btn--disabled");
      btnText.textContent = "Enviar mensaje";
      
      // Regenerar Captcha
      a = Math.ceil(Math.random() * 10);
      b = Math.ceil(Math.random() * 10);
      c = a + b;
      GenerarCaptcha();
    });
  }
</script>
