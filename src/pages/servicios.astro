---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Servicios"
  description="Descubre los servicios de coaching personal, ejecutivo, formación y la metodología PSICOLISTICA de Nagore Sanz en Arteixo, A Coruña."
>

  <section class="page-hero" id="page-hero-services">
    <div class="container">
      <span class="page-hero__overline fade-in">Servicios</span>
      <h1 class="page-hero__title fade-in delay-1">Cómo puedo ayudarte</h1>
      <p class="page-hero__subtitle fade-in delay-2">
        Cada proceso es único, cada persona es un mundo
      </p>
    </div>
  </section>

  <!-- Service 1: Personal -->
  <section class="service-detail section" id="personal">
    <div class="container">
      <div class="service-detail__grid">
        <div class="service-detail__content fade-in-left">
          <div class="service-detail__icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </div>
          <span class="service-detail__label">01</span>
          <h2>Coaching <span class="text-sage">Personal</span></h2>
          <div class="divider" style="margin-left:0"></div>
          <p class="service-detail__lead">
            Acompañamiento individual para tu crecimiento personal y bienestar emocional.
          </p>
          <p>
            A través de sesiones personalizadas, trabajamos juntos para identificar tus objetivos, 
            superar bloqueos y desarrollar las herramientas necesarias para una vida plena. 
            Utilizo técnicas de coaching terapéutico adaptadas a tus necesidades específicas.
          </p>
          <ul class="service-detail__list">
            <li>Autoconocimiento y gestión emocional</li>
            <li>Superación de creencias limitantes</li>
            <li>Gestión del cambio y transiciones vitales</li>
            <li>Desarrollo de habilidades personales</li>
            <li>Equilibrio vida personal-profesional</li>
          </ul>
          <a href="/contacto" class="btn btn--primary">Solicitar información</a>
        </div>
        <div class="service-detail__visual fade-in-right">
          <div class="service-detail__card-visual">
            <span>🎯</span>
            <p>Coaching Personal</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service 2: Executive -->
  <section class="service-detail section section--alt" id="ejecutivo">
    <div class="container">
      <div class="service-detail__grid service-detail__grid--reverse">
        <div class="service-detail__visual fade-in-left">
          <div class="service-detail__card-visual service-detail__card-visual--golden">
            <span>💼</span>
            <p>Coaching Ejecutivo</p>
          </div>
        </div>
        <div class="service-detail__content fade-in-right">
          <div class="service-detail__icon service-detail__icon--golden">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
            </svg>
          </div>
          <span class="service-detail__label">02</span>
          <h2>Coaching <span class="text-golden">Ejecutivo</span></h2>
          <div class="divider" style="margin-left:0"></div>
          <p class="service-detail__lead">
            Potencia el rendimiento de tu equipo y organización con coaching especializado.
          </p>
          <p>
            Trabajo con líderes, equipos y organizaciones para desarrollar competencias clave, 
            mejorar la comunicación interna y crear culturas empresariales que impulsen el éxito.
          </p>
          <ul class="service-detail__list">
            <li>Desarrollo de liderazgo</li>
            <li>Dinámicas de equipo y cohesión</li>
            <li>Gestión del talento</li>
            <li>Comunicación efectiva</li>
            <li>Resolución de conflictos</li>
          </ul>
          <a href="/contacto" class="btn btn--primary">Solicitar información</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Service 3: Training -->
  <section class="service-detail section" id="formacion">
    <div class="container">
      <div class="service-detail__grid">
        <div class="service-detail__content fade-in-left">
          <div class="service-detail__icon service-detail__icon--lavender">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
            </svg>
          </div>
          <span class="service-detail__label">03</span>
          <h2>Formación y <span class="text-sage">Talleres</span></h2>
          <div class="divider" style="margin-left:0"></div>
          <p class="service-detail__lead">
            Conferencias, ponencias y sesiones formativas para grupos e instituciones.
          </p>
          <p>
            Diseño e imparto formaciones a medida sobre desarrollo personal, liderazgo, 
            bienestar emocional y gestión del cambio, tanto para empresas como para 
            instituciones públicas y privadas.
          </p>
          <ul class="service-detail__list">
            <li>Conferencias y ponencias especializadas</li>
            <li>Talleres de desarrollo personal y profesional</li>
            <li>Programas formativos a medida</li>
            <li>Eventos corporate y team building</li>
            <li>Formación para instituciones públicas</li>
          </ul>
          <a href="/contacto" class="btn btn--primary">Solicitar información</a>
        </div>
        <div class="service-detail__visual fade-in-right">
          <div class="service-detail__card-visual service-detail__card-visual--lavender">
            <span>📚</span>
            <p>Formación y Talleres</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PSICOLISTICA -->
  <section class="psicolistica section" id="psicolistica">
    <div class="container">
      <div class="psicolistica__content text-center">
        <span class="page-hero__overline fade-in">Metodología Propia</span>
        <h2 class="fade-in delay-1">
          PSICOL<span class="text-golden">Í</span>STICA
        </h2>
        <div class="divider fade-in delay-1"></div>
        <p class="psicolistica__lead fade-in delay-2">
          Un enfoque integral que une <strong>psicología</strong>, <strong>coaching</strong> 
          y <strong>bienestar espiritual</strong> para una transformación completa.
        </p>

        <div class="psicolistica__pillars fade-in delay-3">
          <div class="psicolistica__pillar glass-card">
            <span class="psicolistica__pillar-icon">🧠</span>
            <h3>Salud Psicológica</h3>
            <p>Comprensión profunda de tus patrones mentales y emocionales.</p>
          </div>
          <div class="psicolistica__pillar glass-card">
            <span class="psicolistica__pillar-icon">🏃‍♀️</span>
            <h3>Bienestar Físico</h3>
            <p>El cuerpo como templo y vehículo de tu crecimiento.</p>
          </div>
          <div class="psicolistica__pillar glass-card">
            <span class="psicolistica__pillar-icon">✨</span>
            <h3>Salud Espiritual</h3>
            <p>Conexión con tu esencia y propósito de vida.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="page-cta" id="services-cta">
    <div class="container text-center">
      <h2 class="fade-in">¿Listo/a para empezar?</h2>
      <p class="fade-in delay-1">Reserva tu sesión de descubrimiento gratuita.</p>
      <div class="page-cta__buttons fade-in delay-2">
        <a href="/contacto" class="btn btn--primary">Reservar Sesión</a>
        <a href="tel:+34666146052" class="btn btn--secondary">📞 Llamar ahora</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero {
    padding: calc(var(--header-height) + var(--space-4xl)) 0 var(--space-3xl);
    text-align: center;
    background: var(--gradient-warm);
  }

  .page-hero__overline {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-golden);
    margin-bottom: var(--space-md);
  }

  .page-hero__title { font-size: var(--text-4xl); margin-bottom: var(--space-lg); }

  .page-hero__subtitle {
    font-family: var(--font-subheading);
    font-size: var(--text-xl);
    font-style: italic;
    color: var(--color-sage);
    max-width: 500px;
    margin: 0 auto;
  }

  /* Service Detail */
  .service-detail__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .service-detail__grid--reverse {
    grid-template-columns: 1fr 1.2fr;
  }

  .service-detail__icon {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-xl);
    background: rgba(124, 154, 130, 0.1);
    color: var(--color-sage);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-lg);
  }

  .service-detail__icon--golden { background: rgba(196,149,106,0.1); color: var(--color-golden); }
  .service-detail__icon--lavender { background: rgba(184,169,201,0.1); color: var(--color-lavender); }

  .service-detail__label {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-sage-light);
    opacity: 0.3;
    display: block;
    margin-bottom: var(--space-sm);
  }

  .service-detail__lead {
    font-size: var(--text-lg);
    color: var(--color-forest);
    font-weight: 500;
  }

  .service-detail__list {
    margin: var(--space-xl) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .service-detail__list li {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-size: var(--text-sm);
    color: var(--color-charcoal);
  }

  .service-detail__list li::before {
    content: '✓';
    color: var(--color-sage);
    font-weight: 700;
    flex-shrink: 0;
  }

  .service-detail__card-visual {
    width: 100%;
    aspect-ratio: 4/3;
    background: linear-gradient(135deg, rgba(124,154,130,0.08), rgba(124,154,130,0.02));
    border-radius: var(--radius-2xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    border: 2px solid rgba(124,154,130,0.1);
    font-size: 4rem;
  }

  .service-detail__card-visual--golden {
    background: linear-gradient(135deg, rgba(196,149,106,0.08), rgba(196,149,106,0.02));
    border-color: rgba(196,149,106,0.1);
  }

  .service-detail__card-visual--lavender {
    background: linear-gradient(135deg, rgba(184,169,201,0.08), rgba(184,169,201,0.02));
    border-color: rgba(184,169,201,0.1);
  }

  .service-detail__card-visual p {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    color: var(--color-forest);
    font-weight: 600;
  }

  /* PSICOLISTICA */
  .psicolistica {
    background: var(--gradient-hero);
    color: var(--color-ivory);
    padding: var(--space-5xl) 0;
  }

  .psicolistica h2 {
    color: var(--color-ivory);
    font-size: var(--text-4xl);
  }

  .psicolistica .divider {
    margin: var(--space-lg) auto;
  }

  .psicolistica__lead {
    font-size: var(--text-lg);
    color: rgba(250,250,247,0.8);
    max-width: 600px;
    margin: 0 auto var(--space-3xl);
  }

  .psicolistica__lead strong {
    color: var(--color-golden-light);
  }

  .psicolistica__pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .psicolistica__pillar {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.1);
    padding: var(--space-2xl);
    text-align: center;
  }

  .psicolistica__pillar:hover {
    background: rgba(255,255,255,0.12);
  }

  .psicolistica__pillar-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: var(--space-lg);
  }

  .psicolistica__pillar h3 {
    color: var(--color-ivory);
    font-size: var(--text-lg);
    margin-bottom: var(--space-md);
  }

  .psicolistica__pillar p {
    color: rgba(250,250,247,0.7);
    font-size: var(--text-sm);
    margin: 0;
  }

  /* Page CTA */
  .page-cta {
    padding: var(--space-4xl) 0;
    background: var(--color-sand);
  }
  .page-cta h2 { margin-bottom: var(--space-md); }
  .page-cta p { font-size: var(--text-lg); color: var(--color-charcoal); opacity: 0.8; }
  .page-cta__buttons {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    margin-top: var(--space-xl);
  }

  @media (max-width: 768px) {
    .service-detail__grid,
    .service-detail__grid--reverse {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .service-detail__visual { order: -1; max-width: 400px; margin: 0 auto; }
    .service-detail__content { text-align: center; }
    .service-detail__list { align-items: center; }
    .psicolistica__pillars { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
  }
</style>
