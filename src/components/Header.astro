---
const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/sobre-mi", label: "Sobre Mí" },
  { href: "/servicios", label: "Servicios" },
  { href: "/blog", label: "Blog" },
  { href: "/contacto", label: "Contacto" },
];

const currentPath = Astro.url.pathname;
---

<header class="header" id="header">
  <div class="header__container container">
    <a href="/" class="header__logo" aria-label="Nagore Sanz — Inicio">
      <div
        class="header__logo-wrapper"
        style="display: flex; align-items: center; gap: 10px;"
      >
        <img
          src="/images/logo_ngsnz_lightblue.png"
          alt="Nagore Sanz Coach"
          height="60"
          style="width: auto; height: 60px; object-fit: contain;"
        />

        <!-- <img
          src="/images/logo_flor_bgwhite.png"
          alt="Nagore Sanz Logo Icon"
          width="50"
          height="50"
          style="object-fit: contain;"
        /> -->
      </div>
    </a>

    <!-- Desktop nav (visible on desktop only) -->
    <nav class="header__nav-desktop" aria-label="Navegación principal">
      <ul class="header__nav-list">
        {
          navLinks.map((link) => (
            <li class="header__nav-item">
              <a
                href={link.href}
                class:list={[
                  "header__nav-link",
                  {
                    active:
                      currentPath === link.href ||
                      (link.href !== "/" && currentPath.startsWith(link.href)),
                  },
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a href="/contacto" class="btn btn--primary header__cta">
        Reservar Sesión
      </a>
    </nav>

    <button
      class="header__hamburger"
      id="hamburger-btn"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span class="header__hamburger-line"></span>
      <span class="header__hamburger-line"></span>
      <span class="header__hamburger-line"></span>
    </button>
  </div>
</header>

<!-- Mobile overlay nav (outside header to avoid z-index issues) -->
<div class="mobile-overlay" id="mobile-nav" aria-label="Menú móvil">
  <div class="mobile-overlay__bg"></div>
  <nav class="mobile-overlay__content">
    <ul class="mobile-overlay__list">
      {
        navLinks.map((link, i) => (
          <li
            class="mobile-overlay__item"
            style={`--delay: ${i * 0.06 + 0.1}s`}
          >
            <a
              href={link.href}
              class:list={[
                "mobile-overlay__link",
                {
                  active:
                    currentPath === link.href ||
                    (link.href !== "/" && currentPath.startsWith(link.href)),
                },
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
    <a
      href="/contacto"
      class="btn btn--primary mobile-overlay__cta"
      style="--delay: 0.45s"
    >
      Reservar Sesión
    </a>
    <div
      class="mobile-overlay__footer"
      style="display: flex; flex-direction: column; align-items: center; gap: 10px;"
    >
      <div style="display: flex; align-items: center; gap: 10px;">
        <img
          src="/images/logo_flor_bgwhite.png"
          alt="Nagore Sanz Logo"
          width="34"
          height="34"
          style="object-fit: contain;"
        />
        <img
          src="/images/nagoresanzcoach.png"
          alt="Nagore Sanz Coach"
          height="30"
          style="width: auto; height: 30px; object-fit: contain;"
        />
      </div>
    </div>
  </nav>
</div>

<style>
  /* ===== HEADER BAR ===== */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: var(--header-height);
    display: flex;
    align-items: center;
    background: rgba(250, 250, 247, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(124, 154, 130, 0.1);
    transition: all var(--transition-base);
  }

  .header.scrolled {
    background: rgba(250, 250, 247, 0.95);
    box-shadow: var(--shadow-sm);
  }

  .header__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header__logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    z-index: 1010;
    position: relative;
  }

  .header__logo-icon {
    font-size: 1.75rem;
    line-height: 1;
  }

  .header__logo-text {
    display: flex;
    flex-direction: column;
  }

  .header__logo-name {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-primary);
    line-height: 1.1;
  }

  .header__logo-tagline {
    font-family: var(--font-subheading);
    font-size: var(--text-xs);
    color: var(--color-secondary);
    font-style: italic;
    letter-spacing: 0.05em;
  }

  /* ===== DESKTOP NAV ===== */
  .header__nav-desktop {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
  }

  .header__nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__nav-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-charcoal);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-full);
    transition: all var(--transition-fast);
    position: relative;
    text-decoration: none;
  }

  .header__nav-link::after {
    content: "";
    position: absolute;
    bottom: 2px;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    width: 20px;
    height: 2px;
    background: var(--color-accent);
    border-radius: var(--radius-full);
    transition: transform var(--transition-base);
  }

  .header__nav-link:hover,
  .header__nav-link.active {
    color: var(--color-primary);
  }

  .header__nav-link:hover::after,
  .header__nav-link.active::after {
    transform: translateX(-50%) scaleX(1);
  }

  .header__cta {
    padding: var(--space-sm) var(--space-lg);
    font-size: var(--text-xs);
  }

  /* ===== HAMBURGER ===== */
  .header__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: var(--space-sm);
    z-index: 1010;
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
  }

  .header__hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-primary);
    border-radius: var(--radius-full);
    transition: all var(--transition-base);
    transform-origin: center;
  }

  .header__hamburger.open .header__hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .header__hamburger.open .header__hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .header__hamburger.open .header__hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* ===== MOBILE OVERLAY (completely separate from header) ===== */
  .mobile-overlay {
    display: none; /* Hidden on desktop */
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .header__nav-desktop {
      display: none;
    }

    .header__hamburger {
      display: flex;
    }

    /* Full-screen mobile overlay */
    .mobile-overlay {
      display: block;
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      height: 100dvh;
      z-index: 1005;
      pointer-events: none;
      opacity: 0;
      visibility: hidden;
      transition:
        opacity 0.35s ease,
        visibility 0.35s ease;
    }

    .mobile-overlay.open {
      opacity: 1;
      visibility: visible;
      pointer-events: all;
    }

    /* Solid background with decorative gradient */
    .mobile-overlay__bg {
      position: absolute;
      inset: 0;
      background: var(--color-ivory);
      z-index: 0;
    }

    .mobile-overlay__bg::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(
          ellipse at 20% 30%,
          rgba(124, 154, 130, 0.08) 0%,
          transparent 50%
        ),
        radial-gradient(
          ellipse at 80% 70%,
          rgba(196, 149, 106, 0.06) 0%,
          transparent 50%
        );
    }

    /* Nav content */
    .mobile-overlay__content {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      padding: calc(var(--header-height) + var(--space-xl)) var(--space-xl)
        var(--space-2xl);
    }

    .mobile-overlay__list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-sm);
      width: 100%;
      max-width: 300px;
      text-align: center;
    }

    .mobile-overlay__item {
      width: 100%;
    }

    .mobile-overlay__link {
      display: block;
      font-family: var(--font-heading);
      font-size: var(--text-2xl);
      font-weight: 500;
      color: var(--color-primary);
      padding: var(--space-md) var(--space-lg);
      border-radius: var(--radius-lg);
      text-decoration: none;
      transition: all 0.25s ease;
      /* Stagger animation */
      transform: translateY(25px);
      opacity: 0;
      transition:
        transform 0.4s ease,
        opacity 0.4s ease,
        background 0.2s ease,
        color 0.2s ease;
      transition-delay: 0s;
    }

    .mobile-overlay.open .mobile-overlay__link {
      transform: translateY(0);
      opacity: 1;
      transition-delay: var(--delay);
    }

    .mobile-overlay__link:hover,
    .mobile-overlay__link:active {
      background: rgba(124, 154, 130, 0.1);
      color: var(--color-primary-light);
    }

    .mobile-overlay__link.active {
      background: rgba(124, 154, 130, 0.12);
      color: var(--color-primary-light);
      font-weight: 600;
    }

    /* CTA button */
    .mobile-overlay__cta {
      margin-top: var(--space-xl);
      padding: var(--space-md) var(--space-2xl);
      font-size: var(--text-sm);
      width: 100%;
      max-width: 300px;
      text-align: center;
      justify-content: center;
      transform: translateY(25px);
      opacity: 0;
      transition:
        transform 0.4s ease,
        opacity 0.4s ease;
      transition-delay: 0s;
    }

    .mobile-overlay.open .mobile-overlay__cta {
      transform: translateY(0);
      opacity: 1;
      transition-delay: var(--delay);
    }

    /* Footer branding */
    .mobile-overlay__footer {
      position: absolute;
      bottom: var(--space-2xl);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-xs);
      opacity: 0.3;
    }

    .mobile-overlay__footer span {
      font-size: 1.5rem;
    }

    .mobile-overlay__footer p {
      font-family: var(--font-subheading);
      font-size: var(--text-xs);
      font-style: italic;
      color: var(--color-secondary);
      margin: 0;
    }
  }
</style>

<script>
  // Scroll effect
  const header = document.getElementById("header");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      header?.classList.add("scrolled");
    } else {
      header?.classList.remove("scrolled");
    }
  });

  // Mobile menu
  const hamburger = document.getElementById("hamburger-btn");
  const mobileNav = document.getElementById("mobile-nav");

  hamburger?.addEventListener("click", () => {
    const isOpen = hamburger.classList.toggle("open");
    mobileNav?.classList.toggle("open");
    hamburger.setAttribute("aria-expanded", String(isOpen));
    document.body.style.overflow = isOpen ? "hidden" : "";
  });

  // Close menu on link click
  mobileNav
    ?.querySelectorAll(".mobile-overlay__link, .mobile-overlay__cta")
    .forEach((link) => {
      link.addEventListener("click", () => {
        hamburger?.classList.remove("open");
        mobileNav?.classList.remove("open");
        hamburger?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
      });
    });
</script>
