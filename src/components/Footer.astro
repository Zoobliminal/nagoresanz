---
const currentYear = new Date().getFullYear();
---

<footer class="footer" id="footer">
  <div class="footer__wave">
    <svg
      viewBox="0 0 1440 120"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="none"
    >
      <path
        d="M0 60C240 20 480 100 720 60C960 20 1200 100 1440 60V120H0V60Z"
        fill="currentColor"></path>
    </svg>
  </div>

  <div class="footer__content">
    <div class="container">
      <div class="footer__grid">
        <!-- Brand -->
        <div class="footer__brand">
          <a href="/" class="footer__logo">
            <span class="footer__logo-icon">
              <img
                src="/images/logo_square_bgtransp.png"
                alt="Nagore Sanz Logo"
                width="200"
                height="200"
                style="object-fit: contain;"
              />
            </span>
            <div style="display: flex; flex-direction: column;">
              <!-- <span
                class="footer__logo-name"
                style="text-transform: lowercase; letter-spacing: 0.02em; font-family: var(--font-logo);"
                ><strong style="font-weight: 700;">nagore</strong>sanz</span
              >
              <span
                class="footer__logo-tagline"
                style="font-family: var(--font-logo); font-style: normal; letter-spacing: 0.25em; font-weight: 300; align-self: flex-end; margin-right: -0.25em;"
                >COACH</span
              > -->
            </div>
          </a>
          <p class="footer__description">
            Acompañamiento profesional para tu desarrollo personal, ejecutivo y
            holístico. Transforma tu vida con un enfoque integral.
          </p>
          <div class="footer__social">
            <a
              href="https://www.instagram.com/nagore_sanz_/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
              class="footer__social-link"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                ></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </a>
            <a
              href="https://es.linkedin.com/in/nasanzcoach"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
              class="footer__social-link"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                ></path>
                <rect x="2" y="9" width="4" height="12"></rect>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
            </a>
          </div>
        </div>

        <!-- Quick Links -->
        <div class="footer__column">
          <h4 class="footer__column-title">Navegación</h4>
          <ul class="footer__links">
            <li><a href="/">Inicio</a></li>
            <li><a href="/sobre-mi">Sobre Mí</a></li>
            <li><a href="/servicios">Servicios</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/contacto">Contacto</a></li>
          </ul>
        </div>

        <!-- Services -->
        <div class="footer__column">
          <h4 class="footer__column-title">Servicios</h4>
          <ul class="footer__links">
            <li><a href="/servicios#personal">Coaching Personal</a></li>
            <li><a href="/servicios#ejecutivo">Coaching Ejecutivo</a></li>
            <li><a href="/servicios#formacion">Formación y Talleres</a></li>
            <li>
              <a href="/servicios#psicolistica">Metodología PSICOLISTICA</a>
            </li>
          </ul>
        </div>

        <!-- Contact -->
        <div class="footer__column">
          <h4 class="footer__column-title">Contacto</h4>
          <ul class="footer__contact">
            <li>
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              <span
                >Av. de Santo Estevo de Morás,<br />15142 Arteixo, A Coruña</span
              >
            </li>
            <li>
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                ></path>
              </svg>
              <a href="tel:+34666146052">+34 666 14 60 52</a>
            </li>
            <li>
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              <span>Lun – Vie: 10:00 – 19:30<br />Con cita previa</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-container">
      <p>
        <a href="mailto:zoobliminal@gmail.com">webmaster</a>
        © {currentYear}
        Zoobliminal
      </p>
      <div class="footer__bottom-links">
        <a href="/legal">Aviso Legal</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer__bottom-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .footer__bottom-links a {
    color: rgba(250, 250, 247, 0.5);
    font-size: var(--text-xs);
    transition: color var(--transition-fast);
  }

  .footer__bottom-links a:hover {
    color: var(--color-accent-light);
  }

  .footer {
    position: relative;
    color: var(--color-ivory);
  }

  .footer__wave {
    color: var(--color-primary);
    line-height: 0;
    margin-bottom: -1px;
  }

  .footer__wave svg {
    width: 100%;
    height: 80px;
  }

  .footer__content {
    background: var(--color-primary);
    padding: var(--space-4xl) 0 var(--space-2xl);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: var(--space-3xl);
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .footer__logo-icon {
    font-size: 1.5rem;
  }

  .footer__logo-name {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-ivory);
  }

  .footer__logo-tagline {
    font-family: var(--font-subheading);
    font-size: var(--text-xs);
    color: var(--color-secondary-light);
    font-style: italic;
  }

  .footer__description {
    color: rgba(250, 250, 247, 0.7);
    font-size: var(--text-sm);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .footer__social {
    display: flex;
    gap: var(--space-md);
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-ivory);
    transition: all var(--transition-base);
  }

  .footer__social-link:hover {
    background: var(--color-accent);
    transform: translateY(-3px);
  }

  .footer__column-title {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-ivory);
    margin-bottom: var(--space-lg);
    position: relative;
    padding-bottom: var(--space-sm);
  }

  .footer__column-title::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 30px;
    height: 2px;
    background: var(--color-accent);
    border-radius: var(--radius-full);
  }

  .footer__links li {
    margin-bottom: var(--space-sm);
  }

  .footer__links a {
    color: rgba(250, 250, 247, 0.7);
    font-size: var(--text-sm);
    transition: all var(--transition-fast);
  }

  .footer__links a:hover {
    color: var(--color-accent-light);
    padding-left: var(--space-sm);
  }

  .footer__contact li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
    color: rgba(250, 250, 247, 0.7);
    font-size: var(--text-sm);
  }

  .footer__contact svg {
    flex-shrink: 0;
    margin-top: 3px;
    color: var(--color-secondary-light);
  }

  .footer__contact a {
    color: rgba(250, 250, 247, 0.7);
    transition: color var(--transition-fast);
  }

  .footer__contact a:hover {
    color: var(--color-accent-light);
  }

  .footer__bottom {
    background: rgba(0, 0, 0, 0.2);
    padding: var(--space-lg) 0;
    text-align: center;
  }

  .footer__bottom p {
    color: rgba(250, 250, 247, 0.5);
    font-size: var(--text-xs);
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }

    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
